# --- Conversation log durability (both optional — see README.md) ---
# Point the log file at a mounted persistent volume so it survives a
# redeploy on hosts that wipe local disk (some free tiers of Render/
# Railway/Fly). Leave unset to keep writing to ./conversations.log.
# LOG_FILE_PATH=/data/conversations.log

# Also POST every conversation turn to an external log drain (a serverless
# function that writes to a database, a logging service, etc.) so the log
# survives redeploys even without a volume. Leave unset to skip this.
# LOG_WEBHOOK_URL=https://your-log-drain.example.com/ticketleo-conversations
